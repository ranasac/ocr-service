{
  "title": "OCR Service Dashboard",
  "uid": "ocr-service",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "OCR Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(ocr_requests_total[1m])",
          "legendFormat": "{{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "OCR Request Latency (p50 / p95 / p99)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ocr_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ocr_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ocr_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(ocr_requests_total{status=\"error\"}[5m])",
          "legendFormat": "errors/s",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Messages Consumed / sec",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(kafka_messages_consumed_total[1m])",
          "legendFormat": "{{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "ML Inference Latency (p95)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ml_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Image Transform Latency (p95)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(image_transform_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
