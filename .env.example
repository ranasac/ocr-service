# Application
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_IMAGE_TOPIC=ocr.images
KAFKA_CONSUMER_GROUP=ocr-consumer-group

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ocr_service

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Storage backend: local | s3 | gcs | adls
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./images

# AWS S3 (when STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=ocr-service-images
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# GCS (when STORAGE_BACKEND=gcs)
# GCS_BUCKET=ocr-service-images
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure ADLS (when STORAGE_BACKEND=adls)
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONTAINER=ocr-service-images
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ML Inference Service
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT=30

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ocr-service
OTEL_ENABLED=true

# Image transformation
IMAGE_RESIZE_WIDTH=800
IMAGE_RESIZE_HEIGHT=800
